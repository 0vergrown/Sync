{
  "type":"apoli:multiple",
  "active":{
    "type":"apoli:active_self",
    "entity_action":{
      "type":"sync:attach_rope",
      "max_length":10,
      "texture":"sync:textures/entity/rope.png"
    },
    "cooldown":1,
    "hud_render":{
      "should_render":false
    },
    "key":{
      "key":"key.sync.custom",
      "continuous":false
    }
  },
  "condition_message":{
    "type":"apoli:action_over_time",
    "entity_action":{
      "type":"apoli:if_else",
      "condition":{
        "type":"sync:attached_to_rope"
      },
      "if_action":{
        "type":"apoli:execute_command",
        "command":"tellraw @s {\"text\":\"You have a rope attached!\",\"color\":\"green\"}"
      },
      "else_action":{
        "type":"apoli:execute_command",
        "command":"tellraw @s {\"text\":\"You do NOT have a rope attached!\",\"color\":\"red\"}"
      }
    },
    "interval":20
  }
}